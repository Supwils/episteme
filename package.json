{
  "name": "episteme",
  "version": "0.0.0",
  "private": true,
  "description": "Episteme · 格致 — 重现人类认识世界的旅程. A visual, immersive knowledge platform spanning ten subjects.",
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "dev": "next dev --turbopack -p 3000",
    "build": "NODE_OPTIONS=--max-old-space-size=8192 next build --turbopack",
    "start": "next start -p 3000",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "bundle-check": "node scripts/physics/bundle-check.mjs",
    "lighthouse": "node scripts/lighthouse.mjs",
    "a11y-scan": "node scripts/a11y-scan.mjs",
    "check-content": "tsx scripts/check-content.ts",
    "gen-philo": "tsx scripts/gen-philo-index.ts",
    "gen-econ": "tsx scripts/gen-econ-index.ts",
    "gen-psych": "tsx scripts/gen-psych-index.ts",
    "gen-life": "tsx scripts/gen-life-index.ts",
    "gen-physics-dialogues": "tsx scripts/gen-physics-dialogues-index.ts",
    "gen-frontier": "tsx scripts/gen-frontier-index.ts",
    "gen-domain": "tsx scripts/gen-domain-index.ts",
    "gen-math": "tsx scripts/gen-math-index.ts",
    "gen-kb": "tsx scripts/gen-kb-index.ts",
    "gen-links": "tsx scripts/gen-wiki-links-index.ts",
    "gen-all": "pnpm gen-philo && pnpm gen-econ && pnpm gen-psych && pnpm gen-life && pnpm gen-physics-dialogues && pnpm gen-frontier && pnpm gen-domain && pnpm gen-math && pnpm gen-kb && pnpm gen-links",
    "gen-narration": "tsx scripts/gen-narration-audio.ts",
    "prebuild": "pnpm gen-all",
    "deploy": "vercel build --prod && vercel deploy --prebuilt --prod --archive=tgz",
    "clean": "rm -rf .next dist coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.0.0",
    "@next/mdx": "^15.0.0",
    "@react-three/drei": "^10.0.0",
    "@react-three/fiber": "^9.0.0",
    "@react-three/postprocessing": "^3.0.0",
    "@vercel/og": "^0.11.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.0.0",
    "gray-matter": "^4.0.3",
    "gsap": "^3.15.0",
    "katex": "^0.17.0",
    "minisearch": "^7.2.0",
    "next": "^15.0.0",
    "next-themes": "^0.4.6",
    "postprocessing": "^6.39.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.170.0",
    "web-vitals": "^5.3.0",
    "zod": "^3.23.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@tailwindcss/typography": "^0.5.15",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@types/katex": "^0.16.8",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.170.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.1.0",
    "chrome-launcher": "^1.2.1",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.0.0",
    "happy-dom": "^15.11.0",
    "husky": "^9.1.7",
    "lighthouse": "^13.4.0",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vitest": "^2.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
