# Universe Knowledge — Environment Variables
# Copy this file to .env.local and fill in values

# ── Portal: Sub-app URLs (for production) ──────────────────
# In development, portal uses Next.js rewrites to proxy to localhost ports.
# In production, set these to your deployed URLs.
NEXT_PUBLIC_UNIVERSE_URL=
NEXT_PUBLIC_HISTORY_URL=
NEXT_PUBLIC_PHILOSOPHY_URL=

# ── Universe-Physics: Optional ─────────────────────────────
# No additional env vars required

# ── Human-History: Optional ────────────────────────────────
# No additional env vars required

# ── Philosophy: Optional ───────────────────────────────────
# No additional env vars required
